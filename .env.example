# Auth mode: oidc | bypass | token
VITE_AUTH_MODE=oidc

# Required when VITE_AUTH_MODE=oidc
VITE_OIDC_AUTHORITY=https://keycloak.example.com/realms/fusion
VITE_OIDC_CLIENT_ID=fusion-spectra
# Optional: defaults to <origin>/auth/callback
# VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback

# Required when VITE_AUTH_MODE=token (long-lived JWT from your OIDC provider)
# VITE_DEV_TOKEN=eyJ...
